# Токен бота от @BotFather
BOT_TOKEN=

# Публичный https URL, на который Telegram шлёт апдейты.
# Вебхук будет установлен на ${WEBHOOK_URL}/webhook
# Для локальной разработки подними туннель (cloudflared / ngrok) и вставь его адрес.
WEBHOOK_URL=

# Секрет для проверки заголовка X-Telegram-Bot-Api-Secret-Token.
# Случайная строка из A-Z, a-z, 0-9, _ и -, не короче 32 символов (макс. 256).
# Например: openssl rand -hex 32
WEBHOOK_SECRET=

# Порт локального HTTP-сервера (по умолчанию 3000)
PORT=3000

# --- База данных (libSQL / Turso) ---
# Прод: подключение к Turso. Адрес — `turso db show --url <db>`,
# токен — `turso db tokens create <db>`. Если TURSO_DATABASE_URL задан,
# DB_PATH игнорируется.
#   TURSO_DATABASE_URL=libsql://<имя-бд>.turso.io
#   TURSO_AUTH_TOKEN=<токен>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Разработка: если TURSO_DATABASE_URL пуст, БД — локальный файл SQLite
# по этому пути (по умолчанию gatekeepeer.sqlite). Никакой облачной
# настройки для локального запуска не нужно.
DB_PATH=gatekeepeer.sqlite

# --- LLM-модерация спама (опционально) ---
# OpenAI-compatible API. Если LLM_API_KEY не задан — модерация выключена целиком.
# Подходит OpenAI, OpenRouter или локальная модель — отличается только LLM_BASE_URL.
#   LLM_BASE_URL=https://api.openai.com/v1        (по умолчанию)
#   LLM_BASE_URL=https://openrouter.ai/api/v1     (пример: OpenRouter)
#   LLM_MODEL=gpt-4o-mini                          (по умолчанию)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
